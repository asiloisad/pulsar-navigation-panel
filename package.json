{
  "name": "navigation-panel",
  "description": "Document outline and navigation panel",
  "repository": "https://github.com/asiloisad/pulsar-navigation-panel",
  "keywords": [
    "navigation",
    "outline",
    "section",
    "marker",
    "bookmark",
    "ASCII",
    "BibTex",
    "LaTeX",
    "Markdown",
    "Python",
    "ReStructured",
    "SOFiSTiK",
    "Sinumerik",
    "Typst"
  ],
  "version": "2.0.1",
  "license": "MIT",
  "engines": {
    "atom": ">=1.100.0 <2.0.0"
  },
  "main": "./lib/main",
  "providedServices": {
    "navigation-panel": {
      "versions": {
        "0.0.1": "serviceProvider"
      }
    }
  },
  "consumedServices": {
    "navigation-adapter": {
      "versions": {
        "1.0.0": "consumeNavigationAdapter"
      }
    }
  },
  "dependencies": {
    "@asiloisad/select-list": "^1.6.0",
    "diacritic": "0.0.2",
    "etch": "^0.14.1"
  },
  "configSchema": {
    "panel": {
      "order": 1,
      "title": "Panel",
      "description": "Panel display and behavior settings.",
      "type": "object",
      "collapsed": true,
      "properties": {
        "defaultSide": {
          "order": 1,
          "title": "Default side",
          "description": "Which side the panel opens on. Restart needed.",
          "type": "string",
          "enum": [
            {
              "description": "Left",
              "value": "left"
            },
            {
              "description": "Right",
              "value": "right"
            }
          ],
          "default": "left"
        },
        "visibility": {
          "order": 2,
          "title": "Visibility mode",
          "description": "Default tree expand/collapse behavior. Can also be changed via command or panel context menu.",
          "type": "integer",
          "enum": [
            {
              "description": "Collapsed",
              "value": 0
            },
            {
              "description": "Expanded",
              "value": 1
            },
            {
              "description": "Auto-collapse",
              "value": 2
            }
          ],
          "default": 1
        },
        "traceVisible": {
          "order": 3,
          "title": "Trace visible headers",
          "description": "Highlight headers visible in the editor viewport and scroll the panel to follow.",
          "type": "boolean",
          "default": true
        },
        "searchBar": {
          "order": 4,
          "title": "Show search bar",
          "description": "Show the search bar at the top of the panel. Restart needed.",
          "type": "boolean",
          "default": true
        },
        "categoryBar": {
          "order": 5,
          "title": "Show category bar",
          "description": "Show the category filter bar at the bottom of the panel. Restart needed.",
          "type": "boolean",
          "default": true
        },
        "textWrap": {
          "order": 6,
          "title": "Wrap text",
          "description": "Wrap long header text instead of showing a horizontal scrollbar. Restart needed.",
          "type": "boolean",
          "default": true
        }
      }
    },
    "editor": {
      "order": 2,
      "title": "Editor",
      "description": "Editor navigation and marker settings.",
      "type": "object",
      "collapsed": true,
      "properties": {
        "markLines": {
          "order": 1,
          "title": "Mark section lines",
          "description": "Decorate section lines in the gutter or text. Style can be customized in `style.less`. Restart needed.",
          "type": "boolean",
          "default": true
        },
        "markerUserLevel": {
          "order": 2,
          "title": "User-level marker colors",
          "description": "Use the user-assigned section level for marker color instead of the real level. Restart needed.",
          "type": "boolean",
          "default": false
        },
        "markerType": {
          "order": 3,
          "title": "Marker type",
          "description": "Which parts of the line to decorate. Restart needed.",
          "type": "string",
          "enum": [
            {
              "description": "Line",
              "value": "line"
            },
            {
              "description": "Line number",
              "value": "line-number"
            },
            {
              "description": "Text",
              "value": "text"
            },
            {
              "description": "Line & line number",
              "value": "line&line-number"
            },
            {
              "description": "Text & line number",
              "value": "text&line-number"
            }
          ],
          "default": "line"
        },
        "scrollPosition": {
          "order": 4,
          "title": "Scroll position",
          "description": "Scroll zone as % of viewport height. Single value e.g. `25` always scrolls cursor to that position. Two values e.g. `10-75` define a lazy zone — scrolls only when cursor leaves it. 0 = top, 100 = bottom.",
          "type": "string",
          "default": "0-50"
        },
        "maxHeadingDepth": {
          "order": 5,
          "title": "Max heading depth",
          "description": "Maximum section level to include in the outline (real level, not user level). Refocus needed.",
          "type": "integer",
          "minimum": 1,
          "default": 9
        }
      }
    },
    "scanners": {
      "order": 3,
      "title": "Scanners",
      "description": "Enable or disable individual built-in language scanners.",
      "type": "object",
      "collapsed": true,
      "properties": {
        "asciidoc": {
          "order": 1,
          "title": "AsciiDoc",
          "type": "boolean",
          "default": true
        },
        "bibtex": {
          "order": 2,
          "title": "BibTeX",
          "type": "boolean",
          "default": true
        },
        "clike": {
          "order": 3,
          "title": "C / C# / C++",
          "type": "boolean",
          "default": true
        },
        "javascript": {
          "order": 4,
          "title": "JavaScript / TypeScript",
          "type": "boolean",
          "default": true
        },
        "latex": {
          "order": 5,
          "title": "LaTeX",
          "type": "boolean",
          "default": true
        },
        "markdown": {
          "order": 6,
          "title": "Markdown",
          "type": "boolean",
          "default": true
        },
        "python": {
          "order": 7,
          "title": "Python",
          "type": "boolean",
          "default": true
        },
        "rest": {
          "order": 8,
          "title": "reStructuredText",
          "type": "boolean",
          "default": true
        },
        "sinumerik": {
          "order": 9,
          "title": "Sinumerik",
          "type": "boolean",
          "default": true
        },
        "sofistik": {
          "order": 10,
          "title": "SOFiSTiK",
          "type": "boolean",
          "default": true
        },
        "tasklist": {
          "order": 11,
          "title": "Tasklist",
          "type": "boolean",
          "default": true
        },
        "typst": {
          "order": 12,
          "title": "Typst",
          "type": "boolean",
          "default": true
        }
      }
    },
    "latex": {
      "order": 4,
      "title": "LaTeX",
      "description": "LaTeX scanner settings.",
      "type": "object",
      "collapsed": true,
      "properties": {
        "commands": {
          "type": "object",
          "title": "Section commands",
          "description": "Regex pattern matched against the LaTeX command name. Use `|` to match multiple names. Case-sensitive, no capture groups allowed. Refocus needed.",
          "properties": {
            "4": {
              "order": 4,
              "title": "Level 4 — part",
              "type": "string",
              "default": "part\\*?"
            },
            "5": {
              "order": 5,
              "title": "Level 5 — chapter",
              "type": "string",
              "default": "chapter\\*?"
            },
            "6": {
              "order": 6,
              "title": "Level 6 — section",
              "type": "string",
              "default": "section\\*?"
            },
            "7": {
              "order": 7,
              "title": "Level 7 — subsection",
              "type": "string",
              "default": "subsection\\*?"
            },
            "8": {
              "order": 8,
              "title": "Level 8 — subsubsection",
              "type": "string",
              "default": "subsubsection\\*?"
            },
            "9": {
              "order": 9,
              "title": "Level 9 — paragraph",
              "type": "string",
              "default": "paragraph\\*?"
            },
            "10": {
              "order": 10,
              "title": "Level 10 — subparagraph",
              "type": "string",
              "default": "subparagraph\\*?"
            }
          }
        }
      }
    },
    "sofistik": {
      "order": 5,
      "title": "SOFiSTiK",
      "description": "SOFiSTiK scanner settings.",
      "type": "object",
      "collapsed": true,
      "properties": {
        "showInBlock": {
          "order": 1,
          "title": "Show sections inside define block",
          "type": "boolean",
          "description": "Include sections defined inside `#define` blocks in the outline. Refocus needed.",
          "default": true
        },
        "icons": {
          "order": 2,
          "title": "Show chapter/program icons",
          "type": "boolean",
          "description": "Show clickable icons next to chapters and programs for toggling their state. Refocus needed.",
          "default": true
        }
      }
    },
    "tasklist": {
      "order": 6,
      "title": "Tasklist",
      "description": "Tasklist scanner settings.",
      "type": "object",
      "collapsed": true,
      "properties": {
        "useHeaders": {
          "order": 1,
          "title": "Use headers as nodes",
          "description": "Show tasklist headers as outline nodes in the navigation list.",
          "type": "boolean",
          "default": false
        }
      }
    }
  }
}
