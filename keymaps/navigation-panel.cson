'atom-workspace':
  'alt-n': 'navigation-panel:toggle-focus'

".navigation-search":
  'escape': "navigation-panel:clear"
  'tab': 'navigation-panel:toggle-search-focus'

".navigation-panel":
  'escape': 'navigation-panel:clear'
  'tab': 'navigation-panel:toggle-search-focus'
  'up': 'navigation-panel:select-previous-header'
  'down': 'navigation-panel:select-next-header'
  'left': 'navigation-panel:collapse-selected-header'
  'right': 'navigation-panel:expand-selected-header'
  'enter': 'navigation-panel:open-selected-header'
  'alt-enter': 'navigation-panel:open-selected-header-clear-search'
  'ctrl-enter': 'navigation-panel:open-selected-header-add-cursor'

".navigation-panel-list atom-text-editor[mini]":
  'alt-enter': 'select-list:scroll'
